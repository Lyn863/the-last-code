<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>管理后台 - 测试数据</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        /* 简单美化滚动条 */
        ::-webkit-scrollbar { height: 6px; width: 6px; }
        ::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 3px; }
    </style>
</head>
<body class="bg-gray-50 min-h-screen">

    <!-- ===== 密码验证层（可选） ===== -->
    <div id="authOverlay" class="fixed inset-0 bg-white flex items-center justify-center z-50 hidden">
        <div class="bg-white p-8 rounded shadow-lg max-w-sm w-full border">
            <h2 class="text-xl font-light mb-4 text-center">🔐 管理员验证</h2>
            <input type="password" id="passwordInput" placeholder="请输入管理密码" 
                   class="w-full border px-4 py-2 rounded mb-4 text-center focus:outline-none focus:ring-2 focus:ring-blue-300">
            <button onclick="checkPassword()" 
                    class="w-full bg-neutral-800 text-white py-2 rounded hover:bg-neutral-700 transition">
                进入后台
            </button>
            <p id="authError" class="text-red-500 text-sm mt-2 text-center hidden">密码错误</p>
            <p class="text-xs text-gray-400 mt-4 text-center">默认密码: admin123 (可在代码中修改)</p>
        </div>
    </div>

    <!-- ===== 主内容区 ===== -->
    <div id="mainContent" class="max-w-7xl mx-auto p-4 md:p-8">
        <!-- 头部 -->
        <div class="flex flex-col md:flex-row md:items-center md:justify-between mb-8 gap-4">
            <h1 class="text-3xl font-light text-gray-800">📊 测试数据管理后台</h1>
            <a href="index.html" class="text-sm text-blue-600 hover:underline self-start md:self-center">
                ← 返回测试首页
            </a>
        </div>

        <!-- 统计卡片 -->
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
            <div class="bg-white p-5 rounded shadow-sm">
                <p class="text-gray-500 text-sm">总测试次数</p>
                <p id="totalCount" class="text-3xl font-light mt-1">0</p>
            </div>
            <div class="bg-white p-5 rounded shadow-sm">
                <p class="text-gray-500 text-sm">今日新增</p>
                <p id="todayCount" class="text-3xl font-light mt-1">0</p>
            </div>
            <div class="bg-white p-5 rounded shadow-sm">
                <p class="text-gray-500 text-sm">最近测试</p>
                <p id="lastTestTime" class="text-lg font-light mt-1 text-gray-700">-</p>
            </div>
            <div class="bg-white p-5 rounded shadow-sm flex flex-col justify-center">
                <button onclick="clearAllData()" 
                        class="text-red-500 text-sm hover:text-red-700 transition self-start">
                    🗑 清空所有数据
                </button>
            </div>
        </div>

        <!-- 导出按钮 -->
        <div class="flex gap-3 mb-6 flex-wrap">
            <button onclick="exportJSON()" 
                    class="bg-blue-600 text-white px-5 py-2 rounded hover:bg-blue-700 transition shadow-sm">
                📥 导出 JSON
            </button>
            <button onclick="exportCSV()" 
                    class="bg-green-600 text-white px-5 py-2 rounded hover:bg-green-700 transition shadow-sm">
                📊 导出 CSV (Excel)
            </button>
            <button onclick="location.reload()" 
                    class="bg-gray-200 text-gray-700 px-5 py-2 rounded hover:bg-gray-300 transition">
                🔄 刷新数据
            </button>
        </div>

        <!-- 数据表格 -->
        <div class="bg-white rounded shadow-sm overflow-x-auto">
            <table class="min-w-full text-sm">
                <thead>
                    <tr class="bg-gray-100 text-gray-600 uppercase text-xs tracking-wider">
                        <th class="px-4 py-3 text-left">时间</th>
                        <th class="px-4 py-3 text-left">人格类型</th>
                        <th class="px-4 py-3 text-center">E</th>
                        <th class="px-4 py-3 text-center">N</th>
                        <th class="px-4 py-3 text-center">A</th>
                        <th class="px-4 py-3 text-center">C</th>
                        <th class="px-4 py-3 text-center">O</th>
                        <!-- 最后十题列头 -->
                        <th class="px-2 py-3 text-center">Q1</th>
                        <th class="px-2 py-3 text-center">Q2</th>
                        <th class="px-2 py-3 text-center">Q3</th>
                        <th class="px-2 py-3 text-center">Q4</th>
                        <th class="px-2 py-3 text-center">Q5</th>
                        <th class="px-2 py-3 text-center">Q6</th>
                        <th class="px-2 py-3 text-center">Q7</th>
                        <th class="px-2 py-3 text-center">Q8</th>
                        <th class="px-2 py-3 text-center">Q9</th>
                        <th class="px-2 py-3 text-center">Q10</th>
                    </tr>
                </thead>
                <tbody id="dataTable" class="divide-y divide-gray-100 text-gray-700">
                    <!-- JS动态填充 -->
                </tbody>
            </table>
            <div id="emptyState" class="text-center py-12 text-gray-400 hidden">
                暂无测试数据
            </div>
        </div>
    </div>

    <script>
        // ========== 配置：是否启用密码保护 ==========
        const ENABLE_PASSWORD = false;   // 改为 true 则开启密码验证
        const ADMIN_PASSWORD = 'admin123'; // 修改为你自己的密码

        // ========== 密码验证逻辑 ==========
        if (ENABLE_PASSWORD) {
            document.getElementById('authOverlay').classList.remove('hidden');
            document.getElementById('mainContent').classList.add('hidden');
        }

        function checkPassword() {
            const input = document.getElementById('passwordInput').value;
            if (input === ADMIN_PASSWORD) {
                document.getElementById('authOverlay').classList.add('hidden');
                document.getElementById('mainContent').classList.remove('hidden');
                loadData();
            } else {
                document.getElementById('authError').classList.remove('hidden');
            }
        }

        // 回车键触发验证
        document.addEventListener('DOMContentLoaded', () => {
            const pwdInput = document.getElementById('passwordInput');
            if (pwdInput) {
                pwdInput.addEventListener('keypress', (e) => {
                    if (e.key === 'Enter') checkPassword();
                });
            }
            // 如果未启用密码，直接加载数据
            if (!ENABLE_PASSWORD) {
                loadData();
            }
        });

        // ========== 数据加载与展示 ==========
        function loadData() {
            const results = JSON.parse(localStorage.getItem('allTestResults') || '[]');
            
            // 统计
            document.getElementById('totalCount').textContent = results.length;
            
            // 今日新增
            const today = new Date().toISOString().split('T')[0];
            const todayResults = results.filter(r => r.timestamp && r.timestamp.startsWith(today));
            document.getElementById('todayCount').textContent = todayResults.length;
            
            // 最近测试时间
            if (results.length > 0) {
                const last = results[results.length - 1].timestamp;
                document.getElementById('lastTestTime').textContent = 
                    new Date(last).toLocaleString('zh-CN');
            } else {
                document.getElementById('lastTestTime').textContent = '-';
            }

            // 填充表格
            const tbody = document.getElementById('dataTable');
            const emptyState = document.getElementById('emptyState');
            
            if (results.length === 0) {
                tbody.innerHTML = '';
                emptyState.classList.remove('hidden');
                return;
            }
            emptyState.classList.add('hidden');

            tbody.innerHTML = results.map(r => {
                const lastTen = r.lastTenAnswers || [];
                // 保证恰好10个格子，不足补 '-'
                const tenCells = Array.from({ length: 10 }, (_, i) => 
                    lastTen[i] !== undefined ? lastTen[i] : '-'
                ).map(val => `<td class="px-2 py-3 text-center whitespace-nowrap">${val}</td>`).join('');

                return `
                    <tr class="hover:bg-gray-50 transition">
                        <td class="px-4 py-3 whitespace-nowrap">${new Date(r.timestamp).toLocaleString('zh-CN')}</td>
                        <td class="px-4 py-3 font-medium">${r.personalityType || '-'}</td>
                        <td class="px-4 py-3 text-center">${r.scores?.E ?? '-'}</td>
                        <td class="px-4 py-3 text-center">${r.scores?.N ?? '-'}</td>
                        <td class="px-4 py-3 text-center">${r.scores?.A ?? '-'}</td>
                        <td class="px-4 py-3 text-center">${r.scores?.C ?? '-'}</td>
                        <td class="px-4 py-3 text-center">${r.scores?.O ?? '-'}</td>
                        ${tenCells}
                    </tr>
                `;
            }).join('');
        }

        // ========== 导出 JSON ==========
        function exportJSON() {
            const results = localStorage.getItem('allTestResults') || '[]';
            const blob = new Blob([results], { type: 'application/json' });
            downloadBlob(blob, 'personality-test-results.json');
        }

        // ========== 导出 CSV（含最后十题） ==========
        function exportCSV() {
            const results = JSON.parse(localStorage.getItem('allTestResults') || '[]');
            
            // CSV 表头
            let csv = '时间,人格类型,E,N,A,C,O,Q1,Q2,Q3,Q4,Q5,Q6,Q7,Q8,Q9,Q10\n';
            
            results.forEach(r => {
                const lastTen = r.lastTenAnswers || [];
                const ten = Array.from({ length: 10 }, (_, i) => lastTen[i] ?? '');
                
                csv += [
                    r.timestamp || '',
                    r.personalityType || '',
                    r.scores?.E ?? '',
                    r.scores?.N ?? '',
                    r.scores?.A ?? '',
                    r.scores?.C ?? '',
                    r.scores?.O ?? '',
                    ...ten
                ].join(',') + '\n';
            });
            
            // 添加 BOM 保证 Excel 正确识别中文
            const blob = new Blob(['\uFEFF' + csv], { type: 'text/csv;charset=utf-8;' });
            downloadBlob(blob, 'personality-test-results.csv');
        }

        // 通用下载函数
        function downloadBlob(blob, filename) {
            const url = URL.createObjectURL(blob);
            const a = document.createElement('a');
            a.href = url;
            a.download = filename;
            document.body.appendChild(a);
            a.click();
            document.body.removeChild(a);
            URL.revokeObjectURL(url);
        }

        // ========== 清空数据 ==========
        function clearAllData() {
            if (confirm('确定要删除所有测试数据吗？此操作不可恢复！')) {
                localStorage.removeItem('allTestResults');
                loadData();
            }
        }
    </script>
</body>
</html>
